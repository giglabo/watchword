#!/usr/bin/env bash
#
# Pre-commit hook: scan staged changes for secrets using gitleaks.
#
# Install: ./scripts/install-hooks.sh
# Requires: gitleaks (https://github.com/gitleaks/gitleaks#installing)
#

set -euo pipefail

# Check if gitleaks is installed
if ! command -v gitleaks &>/dev/null; then
  echo "WARNING: gitleaks is not installed — skipping secret scan."
  echo "Install it to enable pre-commit secret detection:"
  echo "  brew install gitleaks          # macOS"
  echo "  scoop install gitleaks         # Windows"
  echo "  https://github.com/gitleaks/gitleaks#installing"
  exit 0
fi

echo "Running gitleaks on staged changes..."

# --staged scans only what's about to be committed
gitleaks git --staged --verbose --config .gitleaks.toml

echo "No secrets detected."
